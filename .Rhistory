dnb_bib <- read.csv("~/Users/pulsatilla/Mapping-Bachmann/data")
#Extract titles in translations for a list of authors in Deutsche Nationalbibliothek Datenshop and export as csv
#Query: (spo=ger and (atr="Bachmann, Ingeborg")) or (spo=ger and (atr="Aichinger, Ilse")) or (spo=ger and (atr="Müller, Herta")) or (spo=ger and (atr="Tawada, Yoko")) or (spo=ger and (atr="Stefan, Verena")) or (spo=ger and (atr="Özdamar, Emine Sevgi"))
dnb_bib <- read.csv("~/Mapping-Bachmann/data/Excel_20260702_103219.csv", sep=",")
View(dnb_bib)
View(dnb_bib)
onb_bachmann <- read.csv("~/Mapping-Bachmann/data/Excel_20260702_103219.csv", sep=",")
## Percentages of titles by female authors per year
#Did it get better after 2014?
onb_bachmann <- as.data.frame(table(onb_bachmann$Jahr.Datierung))
#Extract titles in translations for a list of authors in Deutsche Nationalbibliothek Datenshop and export as csv
onb_bachmann <- read.csv("~/Mapping-Bachmann/data/Excel_20260702_103219.csv", sep=",")
## Percentages of titles by female authors per year
#Did it get better after 2014?
onb_bachmann_year <- as.data.frame(table(onb_bachmann$Jahr.Datierung))
View(onb_bachmann_year)
df <- onb_bachmann %>% mutate(Jahr_tmp = gsub("[\[\]\s]+", " ", Jahr/Datierung)) %>% mutate(Jahr_clean = str_extract(Jahr_tmp, "\b\d{4}\b")) %>% select(-Jahr_tmp)
##clean year
df <- onb_bachmann %>% mutate(year_matches = str_extract_all(Jahr/Datierung, "\b\d{4}\b")) %>% mutate(Jahr_clean = sapply(year_matches, function(x) if(length(x)==0) NA else min(as.integer(x)))) %>% select(-year_matches)
##clean year
df <- onb_bachmann %>% mutate(Jahr_clean = str_extract(Jahr/Datierung, "\\b\\d{4}\\b"))
View(onb_bachmann)
##clean year
df <- onb_bachmann %>% mutate(Jahr_clean = str_extract(Jahr.Datierung, "\\b\\d{4}\\b"))
View(df)
View(df)
##clean year
onb_bachmann <- onb_bachmann %>% mutate(Jahr.Datierung = str_extract(Jahr.Datierung, "\\b\\d{4}\\b"))
View(onb_bachmann)
onb_bachmann_year <- as.data.frame(table(onb_bachmann$Jahr.Datierung))
View(onb_bachmann_year)
onb_bachmann_year = onb_bachmann_year[-1,]
View(onb_bachmann_year)
ggplot(onb_bachmann_year, aes(x=Var1, y=perc)) +
geom_bar(stat="identity", fill = "darkolivegreen4") + xlab("Year") + ylab("Percentage of female authors") +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5)) + theme(axis.text.x=element_text(angle=45, hjust=0.5))
ggplot(onb_bachmann_year, aes(x=Var1, y=Freq)) +
geom_bar(stat="identity", fill = "darkolivegreen4") + xlab("Year") + ylab("Percentage of female authors") +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5)) + theme(axis.text.x=element_text(angle=45, hjust=0.5))
ggplot(onb_bachmann_year, aes(x=Var1, y=Freq)) +
geom_bar(stat="identity", fill = "darkolivegreen4") + xlab("Year") + ylab("Percentage of female authors") +
theme(axis.text.x = element_text(angle = 90, vjust = 1)) + theme(axis.text.x=element_text(angle=45, hjust=0.5))
ggplot(onb_bachmann_year, aes(x=Var1, y=Freq)) +
geom_bar(stat="identity", fill = "darkolivegreen4") + xlab("Year") + ylab("Percentage of female authors") +
theme(axis.text.x = element_text(angle = 180, vjust = 0.5)) + theme(axis.text.x=element_text(angle=45, hjust=0.5))
ggplot(onb_bachmann_year, aes(x=Var1, y=Freq)) +
geom_bar(stat="identity", fill = "darkolivegreen4") + xlab("Year") + ylab("Percentage of female authors") +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust = 1)) + theme(axis.text.x=element_text(angle = 90, vjust = 0.5, hjust = 1))
ggplot(onb_bachmann_year, aes(x=Var1, y=Freq)) +
geom_bar(stat="identity", fill = "darkolivegreen4") + xlab("Year") + ylab("Sum of Ingeborg Bachmann's titles") +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5, hjust = 1)) + theme(axis.text.x=element_text(angle = 90, vjust = 0.5, hjust = 1))
ggsave("figures/020726_onb_bachmann_titles_peryear.png", width = 6, height = 4, dpi=300)
onb_bachmann_langs <- as.data.frame(table(onb_bachmann$Sprache))
View(onb_bachmann_langs)
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Sprache = ifelse(str_detect(Sprache, ":"), "multilingual", Sprache))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Sprache = ifelse(str_detect(Sprache, ";"), "multilingual", Sprache))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Sprache = ifelse(str_detect(onb_bachmann$Sprache, ";"), "multilingual", Sprache))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Sprache = ifelse(str_detect(onb_bachmann$Sprache, ";"), "multilingual", onb_bachmann$Sprache))
View(onb_bachmann_year)
View(onb_bachmann_langs)
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Var1 = ifelse(str_detect(onb_bachmann$Var1, ";"), "multilingual", Var1))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Var1 = ifelse(str_detect(onb_bachmann_langs$Var1, ";"), "multilingual", Var1))
View(onb_bachmann_langs)
onb_bachmann_langs <- as.data.frame(table(onb_bachmann$Sprache))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Var1 = ifelse(str_detect(Var1, ";"), "multilingual", Var1))
View(onb_bachmann_langs)
onb_bachmann_langs <- as.data.frame(table(onb_bachmann$Sprache))
onb_bachmann_langs %>% mutate(Var1 = ifelse(is.na(Var1), NA_character_, ifelse(str_detect(Var1, "[,;/]"), "multilingual", Var1)))
onb_bachmann_langs <- as.data.frame(table(onb_bachmann$Sprache))
onb_bachmann_langs %>% mutate(Var1 = ifelse(is.na(Var1), NA_character_, ifelse(str_detect(Var1, "[,;/]"), "multilingual", Var1)))
onb_bachmann_langs <- as.data.frame(table(onb_bachmann$Sprache))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Var1 = ifelse(str_detect(Var1, ";"), "multilingual", Var1))
View(onb_bachmann_langs)
onb_bachmann_langs <- as.data.frame(table(onb_bachmann$Sprache))
View(onb_bachmann_langs)
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(language = case_when(
is.na(language) ~ NA_character_,
str_detect(language, "[,;/|]") ~ "multilingual",
TRUE ~ language
))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Var1 = case_when(
is.na(Var1) ~ NA_character_,
str_detect(Var1, "[,;/|]") ~ "multilingual",
TRUE ~ Var1
))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Var1 = case_when(
is.na(Var1) ~ NA_character_,
str_detect(Var1, "[;/|]") ~ "multilingual",
TRUE ~ Var1
))
onb_bachmann_langs %>% mutate(Var1 = ifelse(is.na(Var1), NA_character_, ifelse(str_detect(Var1, "[,;/]"), "multilingual", Var1)))
onb_bachmann_langs <- as.data.frame(table(onb_bachmann$Sprache))
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Var1 = as.character(Var1)) %>%
mutate(Var1 = case_when(
is.na(Var1) ~ NA_character_,
str_detect(Var1, "[,;/|]") ~ "multilingual",
TRUE ~ Var1
))
View(onb_bachmann_langs)
onb_bachmann_langs <- onb_bachmann_langs %>%
mutate(Var1 = as.character(Var1)) %>%
mutate(Var1 = case_when(
is.na(Var1) ~ NA_character_,
str_detect(Var1, "[,;/|]") ~ "multilingual",
TRUE ~ Var1
)) %>% group_by(Var1) %>%
summarise(Freq = sum(Freq, na.rm = TRUE)) %>%
ungroup()
View(onb_bachmann_langs)
onb_bachmann_langs = onb_bachmann_langs[-1,]
pie_df <- onb_bachmann_langs %>%
mutate(perc = Freq / sum(Freq) * 100,
lab = paste0(round(perc, 1), "%"))
View(pie_df)
ggplot(pie_df, aes(x = "", y = Freq, fill = Var1)) +
geom_col(width = 1, color = "white") +
coord_polar(theta = "y") +
geom_text(aes(label = lab),
position = position_stack(vjust = 0.5), size = 3) +
theme_void() +
labs(title = "Language distribution (titles)", fill = "Language") +
guides(fill = guide_legend(ncol = 1))
ggplot(pie_df, aes(x = reorder(Var1, Freq), y = Freq, fill = Var1)) +
geom_col(show.legend = FALSE) +
geom_text(aes(label = paste0(Freq, " (", round(perc,1), "%)")),
hjust = -0.1, size = 3) +
coord_flip() +
labs(x = "Language", y = "Frequency (titles)", title = "Language frequencies") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5))
ggsave("figures/020726_onb_bachmann_language_freqs.png", width = 6, height = 4, dpi=300)
ggplot(pie_df %>% filter(!str_detect(Var1, regex("^Deutsch$", ignore_case = TRUE)), aes(x = reorder(Var1, Freq), y = Freq, fill = Var1)) +
geom_col(show.legend = FALSE) +
geom_text(aes(label = paste0(Freq, " (", round(perc,1), "%)")),
hjust = -0.1, size = 3) +
coord_flip() +
labs(x = "Language", y = "Frequency (titles)", title = "Language frequencies") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5))
ggplot(pie_df %>% filter(!str_detect(Var1, regex("^Deutsch$"), ignore_case = TRUE)), aes(x = reorder(Var1, Freq), y = Freq, fill = Var1)) +
geom_col(show.legend = FALSE) +
geom_text(aes(label = paste0(Freq, " (", round(perc,1), "%)")),
hjust = -0.1, size = 3) +
coord_flip() +
labs(x = "Language", y = "Frequency (titles)", title = "Language frequencies") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5))
onb_bachmann_langs %>%
mutate(Var1 = as.character(Var1)) %>% # ensure character, not factor 1
filter(!str_detect(Var1, regex("^Deutsch$", ignore_case = TRUE))) %>% # remove exact "Deutsch"
mutate(perc = Freq / sum(Freq, na.rm = TRUE) * 100) %>% # compute perc for labels
ggplot(aes(x = reorder(Var1, Freq), y = Freq, fill = Var1)) + # pass directly into ggplot 2
geom_col(show.legend = FALSE) +
geom_text(aes(label = paste0(Freq, " (", round(perc,1), "%)")),
hjust = -0.1, size = 3) +
coord_flip() +
labs(x = "Language", y = "Frequency (titles)", title = "Language frequencies (excluding Deutsch)") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 90, vjust = 0.5))
ggsave("figures/020726_onb_bachmann_language_trans_freqs.png", width = 6, height = 4, dpi=300)
